{
  "title": "AWB CRO Dashboard \u2014 Integrated AI Platform",
  "uid": "awb-cro-dashboard",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5m",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "tags": [
    "AWB-AI-2026",
    "CRO",
    "chapter-16"
  ],
  "templating": {
    "list": [
      {
        "name": "DS_AWB_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Credit Portfolio \u2014 Weighted Avg PD (MR-2026-040)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_AWB_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "awb_credit_portfolio_weighted_pd",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Market Risk \u2014 VaR Limit Utilisation (MR-2026-046)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_AWB_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "awb_var_utilisation_ratio",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Liquidity \u2014 LCR vs 100% Floor (MR-2026-044/045)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_AWB_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "awb_lcr_ratio",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "AML \u2014 Open Alerts by Severity (MR-2026-061)",
      "type": "barchart",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_AWB_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by (severity) (awb_aml_open_alerts)",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Model Health \u2014 PSI Drift Breaches, All 23 Systems",
      "type": "stat",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_AWB_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "count(awb_model_psi > 0.2)",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Platform \u2014 Metric Freshness (target <= 15m, DORA RTO)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_AWB_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "time() - max by (service) (awb_metric_last_update_ts)",
          "refId": "A"
        }
      ]
    }
  ]
}